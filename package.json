{
  "name": "nba-poster-generator",
  "version": "1.0.0",
  "description": "NBA 预测市场海报自动化生成工具",
  "main": "generate.js",
  "scripts": {
    "start": "node proxy.js",
    "generate": "node generate.js",
    "generate:nba": "node generate.js --template classic",
    "generate:comprehensive": "node generate.js --template comprehensive",
    "generate:worldcup": "node generate.js --template worldcup",
    "generate:global": "node generate.js --template global",
    "generate:coinprice": "node generate.js --template coinprice",
    "generate:football": "node generate.js --template football",
    "generate:f1": "node generate.js --template f1",
    "generate:f1driver": "node generate.js --template f1driver"
  },
  "dependencies": {
    "puppeteer": "^24.40.0",
    "sharp": "^0.34.5"
  }
}
